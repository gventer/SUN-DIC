@Article{Reu2017,
  author    = {Reu, P and Toussaint, E and Jones, E and Bruck, H and Iadicola, M and Balcaen, R and Turner, D and Siebert, T and Lava, P and Simonsen, M},
  journal   = {Experimental Mechanics},
  title     = {DIC Challenge: Developing Images and Guidelines for Evaluating Accuracy and Resolution of 2D Analyses},
  year      = {2017},
  month     = {12},
  number    = {7},
  pages     = {1067-1099},
  volume    = {58},
  comment   = {This source introduces the **DIC Challenge** ,
an initiative by the Society for Experimental Mechanics (SEM) and the
international DIC society (iDICs) aimed at standardising and evaluating
Digital Image Correlation (DIC) methods. The challenge provides
carefully designed **sample images** and **analysis guidelines** to help users and developers assess the **accuracy and resolution**
of their 2D-DIC software. It details various image sets, including
synthetic and experimental ones, designed to test different aspects of
DIC analysis like noise, contrast, and interpolation bias. The paper
also discusses the initial results from a comparison of 12 commercial
and academic DIC codes using two specific image sets, highlighting the
important trade-off between **spatial resolution and filtering**.},
  date      = {2017-12-11},
  day       = {11},
  doi       = {10.1007/s11340-017-0349-0},
  file      = {:Reu2017 - DIC Challenge_ Developing Images and Guidelines for Evaluating Accuracy and Resolution of 2D Analyses.pdf:PDF},
  publisher = {Springer Science and Business Media LLC},
}

