@Article{Gao2015,
  author    = {Gao, Y.and Cheng, T. and Su, Y. and Xu, X. and Zhang, Y. and Zhang, Q.},
  journal   = {Optics and Lasers in Engineering},
  title     = {High-efficiency and high-accuracy digital image correlation for three-dimensional measurement},
  year      = {2015},
  pages     = {73--80},
  volume    = {65},
  comment   = {This paper focuses on improving the computational **efficiency** and measurement **accuracy** of **Digital Image Correlation (DIC)** , particularly for **three-dimensional (3D-DIC)** applications where non-uniform deformation is significant due to stereo view angles. It compares the **forward additive Gauss--Newton (FA-GN)** and **inverse compositional Gauss--Newton (IC-GN)** algorithms, utilizing both first-order and second-order shape functions. A new **IC-GN algorithm with a second-order shape function (IC-GN2)** is proposed, which eliminates the need to repeatedly calculate the Hessian matrix in each iteration, a major inefficiency in the FA-GN method. Theoretical and experimental validations demonstrate that **IC-GN2** offers the **highest accuracy** among the tested methods (FA-GN1, FA-GN2, IC-GN1, IC-GN2), being approximately **one order higher** than IC-GN1 for non-uniform deformation, and is the **second fastest** , being roughly **2 to 2.3 times faster** than FA-GN2 while achieving similar accuracy. Based on these findings, a high-efficiency and high-accuracy strategy for 3D-DIC is suggested, which leverages IC-GN2 for the critical stereo correspondence between left and right images (an equivalent non-uniform deformation) and IC-GN1 for the correlations within left or right image sequences (where deformation can often be considered uniform).},
  doi       = {10.1016/j.optlaseng.2014.05.013},
  file      = {:Gao2015 - High Efficiency and High Accuracy Digital Image Correlation for Three Dimensional Measurement.pdf:PDF},
  publisher = {Elsevier Ltd.},
}

@Article{Chen2022,
  author    = {Chen, B. and Jungstedt, E.},
  journal   = {Optics and Lasers in Engineering},
  title     = {Fast and large-converge-radius inverse compositional {L}evenberg–{M}arquardt algorithm for digital image correlation: principle, validation, and open-source toolbox},
  year      = {2022},
  month     = {4},
  pages     = {106930},
  volume    = {151},
  comment   = {This research introduces an advanced **inverse compositional Levenberg--Marquardt (IC-LM) algorithm** designed to improve **digital image correlation (DIC)** ,
a technique used for measuring surface deformation. The new algorithm
effectively blends features of existing methods to offer a **larger convergence radius** and **faster convergence speed** . To enhance its robustness and efficiency, the authors propose a **normalization strategy** for initializing parameters, and they also integrate a **reliability-guided displacement tracking strategy**
to improve the initial estimations. The paper provides detailed
principles, validates the algorithm through various tests, and makes an **open-source MATLAB toolbox** available for other researchers.},
  date      = {2022-04},
  doi       = {10.1016/j.optlaseng.2021.106930},
  file      = {:Chen2022 - Fast and Large Converge Radius Inverse Compositional Levenberg–Marquardt Algorithm for Digital Image Correlation_ Principle, Validation, and Open Source Toolbox.pdf:PDF},
  publisher = {Elsevier BV},
}

